config ZMK_BEHAVIOR_OS_LAYER
    bool "Auto layer switching based on BLE profile (OS detection)"
    default n

config ZMK_GESTURE_LAYER
    bool "Gesture layer for trackball swipe shortcuts"
    default n

config ZMK_GESTURE_LAYER_INDEX
    int "Gesture layer index in keymap"
    default 10

config ZMK_GESTURE_THRESHOLD
    int "Movement threshold to trigger gesture (sensor units)"
    default 50
